{
  "manifest_version": 3,
  "name": "Amazon BSR Top 100 Collector",
  "version": "1.0.0",
  "description": "Collect the complete Top 100 from an open Amazon Best Sellers page and send it to the analyzer.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://amazon.co.uk/*",
    "https://*.amazon.it/*",
    "https://amazon.it/*",
    "https://*.amazon.de/*",
    "https://amazon.de/*",
    "https://*.amazon.fr/*",
    "https://amazon.fr/*",
    "https://*.amazon.es/*",
    "https://amazon.es/*",
    "https://*.amazon.nl/*",
    "https://amazon.nl/*",
    "https://*.amazon.se/*",
    "https://amazon.se/*",
    "https://*.amazon.pl/*",
    "https://amazon.pl/*",
    "https://*.amazon.co.jp/*",
    "https://amazon.co.jp/*",
    "https://*.amazon.in/*",
    "https://amazon.in/*",
    "https://*.amazon.com.au/*",
    "https://amazon.com.au/*",
    "https://*.amazon.ca/*",
    "https://amazon.ca/*",
    "https://*.amazon.com.mx/*",
    "https://amazon.com.mx/*",
    "https://*.amazon.com.br/*",
    "https://amazon.com.br/*",
    "https://*.amazon.sg/*",
    "https://amazon.sg/*",
    "https://*.amazon.ae/*",
    "https://amazon.ae/*",
    "https://*.amazon.sa/*",
    "https://amazon.sa/*",
    "https://*.amazon.com.tr/*",
    "https://amazon.com.tr/*"
  ],
  "action": {
    "default_title": "Collect Amazon BSR Top 100",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://amazon.co.uk/*",
        "https://*.amazon.it/*",
        "https://amazon.it/*",
        "https://*.amazon.de/*",
        "https://amazon.de/*",
        "https://*.amazon.fr/*",
        "https://amazon.fr/*",
        "https://*.amazon.es/*",
        "https://amazon.es/*",
        "https://*.amazon.nl/*",
        "https://amazon.nl/*",
        "https://*.amazon.se/*",
        "https://amazon.se/*",
        "https://*.amazon.pl/*",
        "https://amazon.pl/*",
        "https://*.amazon.co.jp/*",
        "https://amazon.co.jp/*",
        "https://*.amazon.in/*",
        "https://amazon.in/*",
        "https://*.amazon.com.au/*",
        "https://amazon.com.au/*",
        "https://*.amazon.ca/*",
        "https://amazon.ca/*",
        "https://*.amazon.com.mx/*",
        "https://amazon.com.mx/*",
        "https://*.amazon.com.br/*",
        "https://amazon.com.br/*",
        "https://*.amazon.sg/*",
        "https://amazon.sg/*",
        "https://*.amazon.ae/*",
        "https://amazon.ae/*",
        "https://*.amazon.sa/*",
        "https://amazon.sa/*",
        "https://*.amazon.com.tr/*",
        "https://amazon.com.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
