{
  "manifest_version": 3,
  "name": "Amazon BSR Top 100 Collector",
  "version": "1.0.0",
  "description": "Collect the complete Top 100 from an open Amazon Best Sellers page and send it to the analyzer.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*"
  ],
  "action": {
    "default_title": "Collect Amazon BSR Top 100",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
